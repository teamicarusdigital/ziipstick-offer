{
  "buildCommand": "",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, nosnippet, noarchive" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/pages/worldwide-favorites", "destination": "/pages/worldwide-favorites/index.html" },
    { "source": "/pages/worldwide-favorites/", "destination": "/pages/worldwide-favorites/index.html" }
  ]
}
